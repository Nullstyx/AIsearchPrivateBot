# Telegram Bot Configuration
# Get the token from @BotFather in Telegram
TELEGRAM_BOT_TOKEN=

# Perplexity API Configuration
# Get the API key at https://www.perplexity.ai/account/api/keys
PERPLEXITY_API_KEY=

# Allowed users (chat_id and available modes)
# User string format:
#   UserX=chat_id=MODE_MASK
# where:
#   - chat_id        — your chat_id (you can get it from @userinfobot)
#   - MODE_MASK      — a string of digits 1, 2, 3:
#         1 — Sonar mode allowed
#         2 — Sonar Pro mode allowed
#         3 — Sonar-reasoning mode allowed
#     Examples:
#         User1=000000000=1     — only Sonar
#         User2=111111111=23    — Sonar Pro and Sonar-reasoning
#         User3=222222222=123   — all three modes
# If nothing is specified after the second '=', then all modes are FORBIDDEN for this user.
# If you don't specify any UserX, access to the bot will be open to all users and all modes.
User1=111111111=123