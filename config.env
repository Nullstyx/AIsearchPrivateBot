# Telegram Bot Configuration
# Получите токен у @BotFather в Telegram
# Создайте бота через @BotFather, скопируйте токен и вставьте ниже
TELEGRAM_BOT_TOKEN=

# Perplexity API Configuration
# Получите API ключ на https://www.perplexity.ai/account/api/keys
# Зарегистрируйтесь на Perplexity, перейдите в настройки API и создайте ключ
PERPLEXITY_API_KEY=

# Разрешенные пользователи (chat_id и доступные режимы)
# Формат строки пользователя:
#   UserX=chat_id=MODE_MASK
# где:
#   - chat_id        — ваш chat_id (узнать можно у бота @userinfobot)
#   - MODE_MASK      — строка из цифр 1, 2, 3:
#         1 — разрешен режим Sonar
#         2 — разрешен режим Sonar Pro
#         3 — разрешен режим Sonar-reasoning
#     Примеры:
#         User1=1823415036=1     — только Sonar
#         User2=111111111=23     — Sonar Pro и Sonar-reasoning
#         User3=222222222=123    — все три режима
# Если после второго знака '=' ничего не указано, то для этого пользователя режимы ЗАПРЕЩЕНЫ.
# Если не указать ни одного UserX, доступ к боту будет открыт для всех пользователей и для всех режимов.
User1=111111111=123